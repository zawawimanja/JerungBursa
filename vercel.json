{
  "version": 2,
  "builds": [
    { "src": "smart-money-tracker/api/chat.js", "use": "@vercel/node" },
    { "src": "smart-money-tracker/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/smart-money-tracker/api/chat.js" },
    { "src": "/(.*)", "dest": "/smart-money-tracker/$1" }
  ]
}
